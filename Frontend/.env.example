# Local dev: leave unset — Vite proxies /api → http://localhost:4000
# VITE_API_BASE_URL=

# Railway frontend (runtime — set on the Frontend service, no rebuild needed):
# Must be the full backend URL — NOT "base" or other placeholders, no /api suffix:
BACKEND_URL=https://meshboard-super-node.up.railway.app

# Optional: bake API URL at build time (not needed if BACKEND_URL is set — serve.js proxies /api)
# VITE_API_BASE_URL=/api

VITE_SUPERNODE_ID=SUPERNODE-ARUSHA-01

# ── Connectivity agent (from repo root)
# BACKEND_URL=https://meshboard-super-node.up.railway.app
# FRONTEND_URL=https://your-frontend.up.railway.app
# npm run connectivity
