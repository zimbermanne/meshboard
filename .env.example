# ── Backend Database
# Railway: link PostgreSQL plugin — PGHOST, PGPORT, PGUSER, PGPASSWORD, PGDATABASE are injected.
# If DATABASE_URL contains placeholder host "base", the backend uses PGHOST automatically.
DATABASE_URL=
PGHOST=
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=railway
DB_HOST=localhost
DB_PORT=5432
DB_NAME=meshboard
DB_USER=postgres
DB_PASSWORD=

# ── Server Configuration
PORT=4000
NODE_ENV=development
SUPERNODE_ID=SUPERNODE-ARUSHA-01

# ── Token Expiry (hours)
TOKEN_EXPIRY_HOURS=48

# ── CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Dashboard auth (set a long random string in production)
JWT_SECRET=change-me-in-production

# ── Migrations (Railway first deploy)
RUN_MIGRATIONS=false
AUTO_MIGRATE=false
# Or after deploy: POST https://meshboard-super-node.up.railway.app/api/setup/migrate

# ── Connectivity agent (scripts/connectivity-agent.js)
# BACKEND_URL=http://localhost:4000
# FRONTEND_URL=http://localhost:3000
# Run: npm run connectivity  |  npm run connectivity:local
