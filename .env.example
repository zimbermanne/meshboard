# ── Backend Database (Railway-specific)
# On Railway, DATABASE_URL is auto-filled when you link a PostgreSQL service
# For local development, provide individual values:
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=meshboard
DB_USER=postgres
DB_PASSWORD=

# ── Server Configuration
PORT=4000
NODE_ENV=development
SUPERNODE_ID=SUPERNODE-ARUSHA-01

# ── Token Expiry (hours)
TOKEN_EXPIRY_HOURS=48

# ── CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Optional: Run migrations on startup (Railway deployment)
RUN_MIGRATIONS=false

# ── Connectivity agent (scripts/connectivity-agent.js)
# BACKEND_URL=http://localhost:4000
# FRONTEND_URL=http://localhost:3000
# Run: npm run connectivity  |  npm run connectivity:local
